<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Accessibility Service -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_accessibility_service"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_light"
            android:textColor="@color/text_secondary"
            android:paddingTop="16dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/status_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvServiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:fontFamily="@font/outfit_light"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvServiceHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:fontFamily="@font/outfit_light"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnEnable"
            style="@style/Widget.NdbBlocker.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_enable" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- Device Admin -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_device_admin"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_light"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/adminDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/status_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvAdminStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:fontFamily="@font/outfit_light"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvAdminHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:fontFamily="@font/outfit_light"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnDeviceAdmin"
            style="@style/Widget.NdbBlocker.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_enable_admin" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- Firebase -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_firebase"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_light"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_firebase_project"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_light"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvFirebaseProject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_light"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_fcm_token"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_light"
                android:textColor="@color/text_secondary" />

            <View
                android:id="@+id/fcmDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/status_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvFcmStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_light"
                android:textColor="@color/text_primary" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
