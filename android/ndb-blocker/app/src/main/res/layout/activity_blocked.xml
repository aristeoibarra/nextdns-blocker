<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="40dp"
    android:background="@color/bg_dark">

    <!-- Blocked Icon -->
    <FrameLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="32dp">

        <View
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/blocked_icon_background" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/blocked_icon"
            android:textSize="40sp" />

    </FrameLayout>

    <!-- App Name -->
    <TextView
        android:id="@+id/tvBlockedApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#E0E0E0"
        android:layout_marginBottom="8dp" />

    <!-- Package -->
    <TextView
        android:id="@+id/tvBlockedPackage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#444444"
        android:fontFamily="monospace"
        android:layout_marginBottom="40dp" />

    <!-- Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/blocked_message"
        android:textSize="15sp"
        android:textColor="#666666"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="48dp" />

    <!-- Go Home -->
    <Button
        android:id="@+id/btnGoHome"
        style="@style/Widget.NdbBlocker.Button"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_go_home" />

</LinearLayout>
